<Window x:Class="WpfApp.Views.GLListingView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:WpfApp.ViewModels"
        xmlns:local="clr-namespace:WpfApp.Views"
        Title="Gamuda General Ledger" 
        Icon="/Resources/Images/icon_logo.png"
        Height="800" 
        Width="1400"
        WindowStartupLocation="CenterScreen"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <!-- Converter for boolean to visibility -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Converter for row number -->
        <local:RowNumberConverter x:Key="RowNumberConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search Panel -->
        <materialDesign:Card Grid.Row="0" Margin="16,16,16,8" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> 
                    <RowDefinition Height="Auto"/> 
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.5*"/> 
                        <ColumnDefinition Width="Auto"/> 
                        <ColumnDefinition Width="*"/> 
                        <ColumnDefinition Width="*"/> 
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="0.75*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="0.75*"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding Companies}"
                              SelectedItem="{Binding SelectedCompany}"
                              DisplayMemberPath="Name"
                              materialDesign:HintAssist.Hint="Select Company"
                              materialDesign:HintAssist.IsFloating="True"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              VerticalAlignment="Center"/>
                    
                    <Border Grid.Column="1" Width="1" Background="{DynamicResource MaterialDesignDivider}" Margin="16,4"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/Resources/Images/icon_logo.png" Width="32" Height="32" Margin="0,0,12,0"/>
                        <Image Source="/Resources/Images/gamuda_logo.png" Height="24" Stretch="Uniform"/>
                    </StackPanel>

                    <Button Grid.Column="8"
                            Command="{Binding ToggleThemeCommand}"
                            Width="120" Height="32" Margin="0,0,8,0"
                            Style="{StaticResource MaterialDesignOutlinedButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon VerticalAlignment="Center" Margin="0,0,8,0">
                                <materialDesign:PackIcon.Style>
                                    <Style TargetType="materialDesign:PackIcon">
                                        <Setter Property="Kind" Value="WeatherNight"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDarkMode}" Value="True">
                                                <Setter Property="Kind" Value="WeatherSunny"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:PackIcon.Style>
                            </materialDesign:PackIcon>
                            <TextBlock VerticalAlignment="Center" FontSize="12">
                                 <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Dark Mode"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDarkMode}" Value="True">
                                                <Setter Property="Text" Value="Light Mode"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/> 
                        <ColumnDefinition Width="2*"/> 
                        <ColumnDefinition Width="Auto"/> 
                        <ColumnDefinition Width="Auto"/> 
                        <ColumnDefinition Width="Auto"/> 
                        <ColumnDefinition Width="Auto"/>    
                        <ColumnDefinition Width="2*"/> 
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" 
                             Text="{Binding JournalNo, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Journal No"
                             materialDesign:HintAssist.IsFloating="True"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,8,0"/>

                    <TextBox Grid.Column="1" 
                             Text="{Binding AccountCode, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Account Code (;)"
                             materialDesign:HintAssist.IsFloating="True"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,16,0"/>

                    <TextBlock Grid.Column="2" Text="Period" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Bold"/>
                    
                    <StackPanel Grid.Column="3" Orientation="Horizontal">
                        <ComboBox ItemsSource="{Binding Months}" SelectedItem="{Binding SelectedFromMonth}" DisplayMemberPath="Text"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}" Width="70" Margin="0,0,4,0" materialDesign:HintAssist.Hint="M"/>
                        <ComboBox ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedFromYear}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}" Width="90" materialDesign:HintAssist.Hint="Y"/>
                    </StackPanel>

                    <TextBlock Grid.Column="4" Text="-" VerticalAlignment="Center" Margin="8,0,8,0"/>

                    <StackPanel Grid.Column="5" Orientation="Horizontal">
                        <ComboBox ItemsSource="{Binding Months}" SelectedItem="{Binding SelectedToMonth}" DisplayMemberPath="Text"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}" Width="70" Margin="0,0,4,0" materialDesign:HintAssist.Hint="M"/>
                        <ComboBox ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedToYear}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}" Width="90" materialDesign:HintAssist.Hint="Y"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding SearchCommand}" Style="{StaticResource MaterialDesignRaisedButton}" 
                                Height="32" Margin="0,0,8,0" ToolTip="Search">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Magnify" Margin="0,0,4,0"/>
                                <TextBlock Text="Search" Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <!-- Export VAS Accounting (Transformed Data) -->
                        <Button Command="{Binding ExportCommand}" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="32" Margin="0,0,8,0" ToolTip="Export VAS Accounting">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileExport" Margin="0,0,4,0"/>
                                <TextBlock Text="VAS"/>
                            </StackPanel>
                        </Button>

                        <!-- Export GL Listing (Raw Data) -->
                        <Button Command="{Binding ExportRawCommand}" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="32" Margin="0,0,8,0"  ToolTip="Export GL Listing">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileExportOutline" Margin="0,0,4,0"/>
                                <TextBlock Text="GLL"/>
                            </StackPanel>
                        </Button>

                        <!--
                        <Button Command="{Binding CloseCommand}" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="32" ToolTip="Close" Click="CloseButton_Click">
                            <materialDesign:PackIcon Kind="Close"/>
                        </Button>
                        -->
                    </StackPanel>
                </Grid>
            </Grid>
        </materialDesign:Card>

        

        <!-- Data Grid -->
        <materialDesign:Card Grid.Row="1" Margin="16,8,16,8" VerticalAlignment="Stretch">
            <Grid>
                <Border Background="#80000000" 
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                        Panel.ZIndex="1000">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                     Value="0"
                                     IsIndeterminate="True"
                                     Width="60"
                                     Height="60"/>
                        <TextBlock Text="Loading..." 
                                   Foreground="White"
                                   FontSize="16"
                                   Margin="0,16,0,0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <TabControl Style="{StaticResource MaterialDesignTabControl}" x:Name="MainTabControl">
                    
                    <TabControl.Resources>
                        <Style TargetType="{x:Type TabPanel}">
                            <Setter Property="HorizontalAlignment" Value="Left"/>
                        </Style>

                        <Style TargetType="TabItem" BasedOn="{StaticResource MaterialDesignTabItem}">
                            <Setter Property="HorizontalAlignment" Value="Left"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="FontWeight" Value="Normal"/>
                            <Setter Property="Padding" Value="15,6"/>
                            <Setter Property="Height" Value="32"/>
                            
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                                    <!-- <Setter Property="FontWeight" Value="Bold"/> -->
                                    <Setter Property="FontSize" Value="14"/>
                                </Trigger>
                                
                                <Trigger Property="IsSelected" Value="False">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                                    <Setter Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TabControl.Resources>

                    <TabItem Header="VAS">
                        <DataGrid ItemsSource="{Binding Transactions}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserReorderColumns="True"
                                  CanUserResizeColumns="True"
                                  CanUserResizeRows="False"
                                  CanUserSortColumns="True"
                                  AlternatingRowBackground="{DynamicResource MaterialDesignDivider}"
                                  materialDesign:DataGridAssist.CellPadding="8"
                                  materialDesign:DataGridAssist.ColumnHeaderPadding="8"
                                  LoadingRow="DataGrid_LoadingRow">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="No." Binding="{Binding STT}" Width="50" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Company" Binding="{Binding CompanyCode}" Width="80"/>
                                <DataGridTextColumn Header="Post Month" Binding="{Binding PostMonth}" Width="90"/>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="90"/>
                                <DataGridTextColumn Header="Journal No" Binding="{Binding JournalNumber}" Width="100"/>
                                <DataGridTextColumn Header="Account" Binding="{Binding AccountCode}" Width="80"/>
                                <DataGridTextColumn Header="Account Name" Binding="{Binding AccountName}" Width="90"/>
                                <DataGridTextColumn Header="VAS Account" Binding="{Binding VASAccount}" Width="80"/>
                                <DataGridTextColumn Header="Corresponding" Binding="{Binding CorrespondingAccount}" Width="80"/>
                                <DataGridTextColumn Header="Debit" Binding="{Binding Debit, StringFormat='#,##0'}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Credit" Binding="{Binding Credit, StringFormat='#,##0'}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Balance" Binding="{Binding Total, StringFormat='#,##0'}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="120"/>
                                <DataGridTextColumn Header="Ref1" Binding="{Binding Ref1}" Width="50"/>
                                <DataGridTextColumn Header="Ref2" Binding="{Binding Ref2}" Width="50"/>
                                <DataGridTextColumn Header="Alloc 1" Binding="{Binding Allocation1}" Width="50"/>
                                <DataGridTextColumn Header="Alloc 2" Binding="{Binding Allocation2}" Width="50"/>
                                <DataGridTextColumn Header="Alloc 3" Binding="{Binding Allocation3}" Width="50"/>
                                <DataGridTextColumn Header="Alloc 4" Binding="{Binding Allocation4}" Width="50"/>
                                <DataGridTextColumn Header="Alloc 5" Binding="{Binding Allocation5}" Width="50"/>
                                <DataGridTextColumn Header="Supplier Code" Binding="{Binding SupplierCode}" Width="100"/>
                                <DataGridTextColumn Header="Supplier Name" Binding="{Binding SupplierName}" Width="100"/>
                                <DataGridTextColumn Header="Modified By" Binding="{Binding UserLastModified}" Width="120"/>
                                <DataGridTextColumn Header="Modified Date" Binding="{Binding DateLastModified}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="GL Listing">
                        <DataGrid ItemsSource="{Binding RawTransactions}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  AlternatingRowBackground="{DynamicResource MaterialDesignDivider}"
                                  materialDesign:DataGridAssist.CellPadding="8"
                                  materialDesign:DataGridAssist.ColumnHeaderPadding="8">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="No." Binding="{Binding STT}" Width="50"/>
                                <DataGridTextColumn Header="Company" Binding="{Binding CompanyCode}" Width="80"/>
                                <DataGridTextColumn Header="Post Month" Binding="{Binding PostMonth}" Width="90"/>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="90"/>
                                <DataGridTextColumn Header="Journal No" Binding="{Binding JournalNumber}" Width="100"/>
                                <DataGridTextColumn Header="Account" Binding="{Binding AccountCode}" Width="80"/>
                                <DataGridTextColumn Header="Account Name" Binding="{Binding AccountName}" Width="90"/>
                                <DataGridTextColumn Header="VAS Account" Binding="{Binding VASAccount}" Width="80"/>
                                <DataGridTextColumn Header="Debit" Binding="{Binding Debit, StringFormat='#,##0'}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Credit" Binding="{Binding Credit, StringFormat='#,##0'}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Balance" Binding="{Binding Total, StringFormat='#,##0'}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="120"/>
                                <DataGridTextColumn Header="Ref1" Binding="{Binding Ref1}" Width="50"/>
                                <DataGridTextColumn Header="Ref2" Binding="{Binding Ref2}" Width="50"/>
                                <DataGridTextColumn Header="Alloc 1" Binding="{Binding Allocation1}" Width="50"/>
                                <DataGridTextColumn Header="Alloc 2" Binding="{Binding Allocation2}" Width="50"/>
                                <DataGridTextColumn Header="Alloc 3" Binding="{Binding Allocation3}" Width="50"/>
                                <DataGridTextColumn Header="Alloc 4" Binding="{Binding Allocation4}" Width="50"/>
                                <DataGridTextColumn Header="Alloc 5" Binding="{Binding Allocation5}" Width="50"/>
                                <DataGridTextColumn Header="Supplier Code" Binding="{Binding SupplierCode}" Width="100"/>
                                <DataGridTextColumn Header="Supplier Name" Binding="{Binding SupplierName}" Width="100"/>
                                <DataGridTextColumn Header="Modified By" Binding="{Binding UserLastModified}" Width="120"/>
                                <DataGridTextColumn Header="Modified Date" Binding="{Binding DateLastModified}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    
                </TabControl>
            </Grid>
        </materialDesign:Card>

        <!-- Status Bar -->
        <materialDesign:ColorZone Grid.Row="2" 
                                  Mode="PrimaryMid" 
                                  Padding="16,8">
            <DockPanel>
                <!-- GL Icon (Left) -->
                <Image DockPanel.Dock="Left"
                       Source="/Resources/Images/icon_logo.png"
                       Width="20" 
                       Height="20"
                       Margin="0,0,12,0"
                       VerticalAlignment="Center"/>
                
                <!-- Status Icon & Message -->
                <materialDesign:PackIcon Kind="InformationOutline" 
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0"/>
                <TextBlock Text="{Binding StatusMessage}" 
                           VerticalAlignment="Center"
                           FontSize="14"/>
                
                <!-- Gamuda Logo (Right) -->
                <Image DockPanel.Dock="Right"
                       Source="/Resources/Images/gamuda_logo.png"
                       Height="16"
                       Margin="16,0,0,0"
                       VerticalAlignment="Center"
                       Opacity="0.7"/>
                
                <!-- Connection Status Indicator (Right, before logo) -->
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right"
                            Margin="0,0,16,0">
                    <Ellipse Width="12" Height="12" 
                             Margin="0,0,8,0"
                             VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="LightGreen"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Disconnected"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Text" Value="Connected"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </materialDesign:ColorZone>
    </Grid>
</Window>